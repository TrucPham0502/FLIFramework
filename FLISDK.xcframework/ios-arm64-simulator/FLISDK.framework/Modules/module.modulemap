framework module FLISDK {
    umbrella header "FLISDK.h"
    export *
    explicit module TPFFmpeg {
        header "FLIFFmpeg.h"
        export *
    }
}

module FLISDK.Swift {
  header "FLISDK-Swift.h"
  requires objc
}
